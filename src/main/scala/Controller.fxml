<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="600.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">

    <BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="600.0">

        <center>
            <GridPane fx:id="boardGrid" BorderPane.alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="389.0" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="422.0" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="389.0" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="422.0" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="389.0" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="422.0" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                </rowConstraints>
            </GridPane>
        </center>

        <bottom>
            <HBox fx:id="lowerBar" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
        </bottom>
        <top>
            <HBox alignment="CENTER" spacing="50" style="-fx-padding: 10; -fx-background-color: #e3a85d;">
                <Label fx:id="playerLabel" text="Player:" />
                <Label fx:id="clockLabel" text="60" />
            </HBox>
        </top>
    </BorderPane>

    <StackPane fx:id="startMenu" managed="true" style="-fx-background-color: rgba(0, 0, 0, 0.75);" visible="true">
        <VBox alignment="CENTER" maxWidth="420" spacing="15" style="-fx-background-color: #e3a85d; -fx-padding: 25; -fx-border-color: black; -fx-border-width: 2;">

            <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Configuração Inicial" />

            <Label text="Quem começa?" />
            <ComboBox fx:id="starterCombo" prefWidth="250" />

            <Label text="Tempo inicial por jogada( colocar tempo invalido colocara 60 por padrao):" />
            <TextField fx:id="timeInput" prefWidth="250" promptText="Ex: 60" />

            <Label text="Par de peças a remover: 1 a 9" />
            <ComboBox fx:id="removalInput" prefWidth="250" />

            <Label maxWidth="360" text="1) Canto superior esquerdo horizontal&#10;2) Canto superior esquerdo vertical&#10;3) Canto superior direito horizontal&#10;4) Canto superior direito vertical&#10;5) Canto inferior esquerdo horizontal&#10;6) Canto inferior esquerdo vertical&#10;7) Canto inferior direito horizontal&#10;8) Canto inferior direito vertical&#10;9) Centro(padrao)" wrapText="true" />

            <Button onAction="#onStartGameClicked" text="Começar Jogo" />
        </VBox>
    </StackPane>

    <StackPane fx:id="winnerOverlay" managed="false" style="-fx-background-color: rgba(0, 0, 0, 0.65);" visible="false">

        <VBox alignment="CENTER" spacing="20">
            <Label fx:id="winnerLabel" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="Black wins!" />

            <Button onAction="#onRestartClicked" text="Restart" />
        </VBox>
    </StackPane>

    <AnchorPane fx:id="coverPane" focusTraversable="true" maxHeight="600" maxWidth="600" minHeight="600" minWidth="600" onKeyPressed="#onCoverKeyPressed" prefHeight="600" prefWidth="600" style="-fx-background-color: #F2D6A2;">
        <Circle fill="WHITE" layoutX="112.0" layoutY="143.0" radius="188.0" stroke="BLACK" strokeType="INSIDE" />
        <Circle fill="BLACK" layoutX="488.0" layoutY="457.0" radius="188.0" stroke="WHITE" strokeType="INSIDE" />
        <Rectangle height="7.0" layoutX="185.0" layoutY="50.0" width="40.0" />
        <Text layoutX="90" layoutY="130" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-size: 96px; -fx-font-weight: bold;" text="KONANE" textAlignment="CENTER" wrappingWidth="420" />

        <Label layoutX="103.0" layoutY="136.0" prefHeight="79.0" prefWidth="181.0" style="-fx-font-size: 15px; -fx-font-weight: bold;" text="    Feito por:&#10;    Flavio Santos     129830&#10;    Duarte Oliveira  129851&#10;    Dinis Sousa        129820">
            <font>
                <Font size="15.0" />
            </font></Label>

        <Rectangle arcHeight="20" arcWidth="20" height="65" layoutX="125" layoutY="455" style="-fx-fill: #E3A85D; -fx-stroke: black; -fx-stroke-width: 2;" width="350" />

        <Text layoutX="125" layoutY="495" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Pressione Enter para começar" textAlignment="CENTER" wrappingWidth="350" />


    </AnchorPane>


</StackPane>
